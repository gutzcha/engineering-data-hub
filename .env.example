# ===
# File Summary
# Path: .env.example
# Type: shell
# Purpose: Environment variable template and runtime configuration contract.
# Primary responsibilities:
# - Domain behavior is summarized for fast onboarding and avoids full-file reread.
# - Core symbols: file-level implementation
# Inputs:
# - Downstream and upstream interactions in the same domain.
# Outputs:
# - API payloads, records, side effects, or UI views depending on file role.
# Dependencies:
# - Shared runtime services and adjacent domain modules.
# Known risks:
# - Validate behavior after migrations, dependency upgrades, or contract changes.
# ===
# 

APP_ENV=dev
APP_HOST=plastic-hub.local
TIME_ZONE=UTC
SECRET_KEY=change-me-before-production
POSTGRES_DB=plastic_hub
POSTGRES_USER=plastic_hub
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://plastic_hub:change-me@db:5432/plastic_hub
REDIS_URL=redis://redis:6379/0
MEILI_MASTER_KEY=change-me

# Required by prepare_client_demo. Set in local .env or secret manager; do not commit real passwords.
RELEASE_ADMIN_PASSWORD=change-me-release-admin-password
MEILI_URL=http://meilisearch:7700
MANAGED_FILE_ROOT=/data/managed
BACKUP_ROOT=/data/backups
MEDIA_ROOT=/data/media
BACKUP_ENV_FILE=/run/plastic-hub/.env
CADDY_EMAIL=it@example.com
CADDY_TLS_DIRECTIVE=tls internal

