  "workflows": [
    {
      "key": "engineering_record_release",
      "label": "Engineering Record Release",
      "name": "Engineering Record Release",
      "states": ["draft", "engineering_review", "quality_review", "released"],
      "transitions": [
        {
          "from": "draft",
          "to": "engineering_review",
          "guard": "required_fields_complete",
          "task_template": "Engineering review"
        },
        {
          "from": "engineering_review",
          "to": "quality_review",
          "guard": "engineering_approval",
          "task_template": "Quality review"
        },
        {
          "from": "quality_review",
          "to": "released",
          "guard": "quality_approval",
          "task_template": "Release record"
        }
      ],
      "release_rules": ["required_fields_complete", "linked_documents_reviewed", "audit_trail_retained"]
    },
    {
      "key": "product_spec_release",
      "label": "Product Spec Release",
      "name": "Product Spec Release",
      "states": ["draft", "technical_review", "approval", "released"],
      "transitions": [
        {
          "from": "draft",
          "to": "technical_review",
          "guard": "spec_number_and_product_required",
          "task_template": "Technical spec review"
        },
        {
          "from": "technical_review",
          "to": "approval",
          "guard": "controlled_document_attached",
          "task_template": "Approver signoff"
        },
        {
          "from": "approval",
          "to": "released",
          "guard": "approval_complete",
          "task_template": "Publish spec revision"
        }
      ],
      "release_rules": ["controlled_document_required", "revision_required", "effective_date_confirmed"]
    },
    {
      "key": "raw_material_approval",
      "label": "Raw Material Approval",
      "name": "Raw Material Approval",
      "states": ["draft", "supplier_review", "technical_review", "approved"],
      "transitions": [
        {
          "from": "draft",
          "to": "supplier_review",
          "guard": "supplier_selected",
          "task_template": "Supplier qualification review"
        },
        {
          "from": "supplier_review",
          "to": "technical_review",
          "guard": "compliance_documents_available",
          "task_template": "Material technical review"
        },
        {
          "from": "technical_review",
          "to": "approved",
          "guard": "technical_and_quality_approval",
          "task_template": "Approve material"
        }
      ],
      "release_rules": ["supplier_required", "tds_or_compliance_document_required", "material_family_required"]
    },
    {
      "key": "project_gate_review",
      "label": "Project Gate Review",
      "name": "Project Gate Review",
      "states": ["idea", "scoping", "development", "launch_review", "closed"],
      "transitions": [
        {
          "from": "idea",
          "to": "scoping",
          "guard": "project_owner_assigned",
          "task_template": "Gate 0 scoping review"
        },
        {
          "from": "scoping",
          "to": "development",
          "guard": "scope_and_target_launch_confirmed",
          "task_template": "Gate 1 development approval"
        },
        {
          "from": "development",
          "to": "launch_review",
          "guard": "trial_and_spec_package_ready",
          "task_template": "Gate 2 launch readiness"
        },
        {
          "from": "launch_review",
          "to": "closed",
          "guard": "launch_approval_complete",
          "task_template": "Close project"
        }
      ],
      "release_rules": ["owner_required", "target_launch_date_tracked", "linked_product_reviewed_when_available"]
    }
  ],
