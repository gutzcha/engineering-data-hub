# Copy this file to .env and replace every placeholder before running the stack.
# Never commit real secrets or passwords.

APP_ENV=dev
DEBUG=true

SECRET_KEY=change-me-before-production
POSTGRES_DB=plastic_hub
POSTGRES_USER=plastic_hub
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://plastic_hub:change-me@db:5432/plastic_hub

MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change-me

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

VITE_API_BASE_URL=/api

# Required by prepare_client_demo. Use a unique local value, not this placeholder.
RELEASE_ADMIN_PASSWORD=change-me-release-admin-password
